# EpiAgent environment — copy to .env and fill in real values locally.

# --- Database ---
EPIAGENT_DB_PATH=./epiagent.db

# --- API host ---
EPIAGENT_HOST=127.0.0.1
EPIAGENT_PORT=8000

# --- External APIs ---
HF_API_TOKEN=
ARTIFICIAL_ANALYSIS_KEY=
ARTIFICIAL_ANALYSIS_BASE=https://artificialanalysis.ai/api/v2
HF_LEADERBOARD_DATASET=open-llm-leaderboard/contents

# --- Ingestion policy ---
EPIAGENT_MIN_DOWNLOADS=1000
EPIAGENT_MIN_PARAMS_B=0.5
EPIAGENT_MAX_PARAMS_B=500
EPIAGENT_MODIFIED_WITHIN_DAYS=90

# --- SMTP (SendGrid / SES / Postfix) ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=epiagent@example.com
ADMIN_EMAILS=ops@example.com

# --- Notification thresholds ---
EPIAGENT_RANK_CHANGE_THRESHOLD=3
